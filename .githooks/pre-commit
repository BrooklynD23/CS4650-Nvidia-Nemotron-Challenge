#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
PYTHON_BIN="$ROOT/.venv/bin/python"

if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="python3"
fi

"$PYTHON_BIN" "$ROOT/scripts/commit_guard.py" pre-commit
exec "$PYTHON_BIN" "$ROOT/scripts/learn_docs_guard.py" "$ROOT/docs/learn"
